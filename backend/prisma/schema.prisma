generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN

  @@map("enum_user_role")
}

model User {
  id        String      @id @default(uuid())
  email     String      @unique
  password  String
  fullName  String
  role      UserRole   @default(USER) @map("role")
  tags      Genre?
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  userMovies           UserMovie[]  @relation("user_movies")
  lists                UserList[]   @relation("user_lists")
  reviews              Review[]     @relation("user_reviews")
  friendshipsRequested Friendship[] @relation("friendship_requester")
  friendshipsReceived  Friendship[] @relation("friendship_addressee")
  sentMessages         Message[]      @relation("sent_messages")
  receivedMessages     Message[]      @relation("received_messages")
  status               UserStatus?    @relation("user_status")
  notifications        Notification[] @relation("user_notifications")

  @@map("users")
}

model Movie {
  id                    String    @id @default(uuid())
  title                 String
  titleNormalized       String    @default("") @map("title_normalized")
  description           String
  countryCodes          String[]  @default(["US"]) @map("country_codes")
  genres                Genre[]
  publishDate           DateTime? @map("publish_date")
  isSerial              Boolean   @default(false) @map("is_serial")
  seasonCount           Int?      @map("season_count")
  episodeCount          Int?      @map("episode_count")
  posterId              String?   @unique @map("poster_id")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  poster     MoviePoster? @relation("movie_poster", fields: [posterId], references: [id])
  reviews    Review[]     @relation("movie_reviews")
  actors     Actor[]      @relation("movie_actors")
  userMovies UserMovie[]  @relation("movie_users")
  listItems  UserListItem[] @relation("movie_list_items")

  @@index([publishDate, title])
  @@index([titleNormalized])
  @@map("movies")
}

model MoviePoster {
  id        String   @id @default(uuid())
  url       String   @default("")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  movie     Movie?   @relation("movie_poster")

  @@map("movie_posters")
}

model Review {
  id        String   @id @default(uuid())
  text      String
  rate      Int      @default(0)
  userId    String   @map("user_id")
  movieId   String   @map("movie_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user  User  @relation("user_reviews", fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  movie Movie @relation("movie_reviews", fields: [movieId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId])
  @@index([movieId])
  @@map("reviews")
}

model Actor {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  movies    Movie[]  @relation("movie_actors")

  @@map("actors")
}

model UserMovie {
  id             String      @id @default(uuid())
  userId         String      @map("user_id")
  movieId        String      @map("movie_id")
  isFavorite     Boolean     @default(false) @map("is_favorite")
  seeLater       Boolean     @default(false) @map("see_later")
  personalRate   Int?        @map("personal_rate")
  watchStatus    WatchStatus @default(NOT_STARTED) @map("watch_status")
  currentSeason  Int?        @map("current_season")
  currentEpisode Int?        @map("current_episode")
  addedAt        DateTime    @default(now()) @map("added_at")
  lastWatchedAt  DateTime?   @map("last_watched_at")
  completedAt    DateTime?   @map("completed_at")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  user  User  @relation("user_movies", fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  movie Movie @relation("movie_users", fields: [movieId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, movieId])
  @@index([userId])
  @@index([movieId])
  @@index([isFavorite])
  @@index([seeLater])
  @@map("user_movies")
}

model UserList {
  id             String         @id @default(uuid())
  userId         String         @map("user_id")
  name           String
  nameNormalized String         @map("name_normalized")
  description    String?
  labels         String[]       @default([])
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  user  User           @relation("user_lists", fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  items UserListItem[] @relation("list_items")

  @@unique([userId, nameNormalized])
  @@index([userId])
  @@map("user_lists")
}

model UserListItem {
  id        String   @id @default(uuid())
  listId    String   @map("list_id")
  movieId   String   @map("movie_id")
  addedAt   DateTime @default(now()) @map("added_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  list  UserList @relation("list_items", fields: [listId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  movie Movie    @relation("movie_list_items", fields: [movieId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([listId, movieId])
  @@index([listId])
  @@index([movieId])
  @@map("user_list_items")
}

enum WatchStatus {
  NOT_STARTED
  WATCHING
  COMPLETED
  DROPPED

  @@map("enum_watch_status")
}

enum Genre {
  ACTION
  DRAMA
  COMEDY
  DETECTIVE
  FAMILY
  FANTASY
  HORROR
  MUSICAL
  ROMANCE
  THRILLER
  WAR
  WESTERN
  DOCUMENTARY
  Sci_fi @map("Sci-fi")

  @@map("enum_genre")
}

model Friendship {
  id          String           @id @default(uuid())
  requesterId String           @map("requester_id")
  addresseeId String           @map("addressee_id")
  status      FriendshipStatus @default(PENDING)
  type        FriendshipType   @default(FRIEND_REQUEST)
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  requester User @relation("friendship_requester", fields: [requesterId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  addressee User @relation("friendship_addressee", fields: [addresseeId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([requesterId, addresseeId])
  @@index([requesterId])
  @@index([addresseeId])
  @@index([status])
  @@map("friendships")
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  REJECTED
  BLOCKED

  @@map("enum_friendship_status")
}

enum FriendshipType {
  FRIEND_REQUEST
  SUBSCRIPTION

  @@map("enum_friendship_type")
}

model Message {
  id         String   @id @default(uuid())
  senderId   String   @map("sender_id")
  receiverId String   @map("receiver_id")
  content    String
  isRead     Boolean  @default(false) @map("is_read")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  sender   User @relation("sent_messages", fields: [senderId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  receiver User @relation("received_messages", fields: [receiverId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([senderId])
  @@index([receiverId])
  @@index([createdAt])
  @@index([isRead])
  @@map("messages")
}

model UserStatus {
  userId     String   @id @map("user_id")
  isOnline   Boolean  @default(false) @map("is_online")
  lastSeenAt DateTime @default(now()) @map("last_seen_at")
  socketId   String?  @map("socket_id")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user User @relation("user_status", fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("user_statuses")
}

enum NotificationType {
  CHAT_MESSAGE
  FRIEND_REQUEST
  FRIEND_ACCEPTED

  @@map("enum_notification_type")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  type      NotificationType
  payload   Json
  readAt    DateTime?        @map("read_at")
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation("user_notifications", fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId, createdAt(sort: Desc)])
  @@map("notifications")
}
